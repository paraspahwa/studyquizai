# ─────────────────────────────────────────
# ReelForge AI — Environment Variables
# ─────────────────────────────────────────
# Copy this file to .env and fill in your values.

# ── OpenAI (required for AI script generation) ──
OPENAI_API_KEY=sk-your-key-here

# ── Database (PostgreSQL) ──
# Docker: Use the default below
# Local: Update with your PostgreSQL credentials
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/reelforge

# ── Authentication (required for JWT tokens) ──
SECRET_KEY=your-super-secret-key-change-in-production-min-32-chars

# ── Razorpay (optional — for payment processing) ──
# Get keys from: https://dashboard.razorpay.com/app/keys
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_test_secret_key
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret

# ── Frontend configuration ──
VITE_API_URL=http://localhost:8000
VITE_RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
VITE_RAZORPAY_MONTHLY_PLAN_ID=plan_xxxxx
VITE_RAZORPAY_YEARLY_PLAN_ID=plan_yyyyy
